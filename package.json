{
  "name": "@vestfoldfylke/loglady",
  "version": "2.0.0",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "pack": "npm run test && rm -rf dist && rm -f vestfoldfylke-loglady-*.tgz && npm run build && npm pack",
    "test": "biome check && node --import tsx --test src/tests/**/*.test.ts",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vestfoldfylke/loglady.git"
  },
  "bugs": {
    "url": "https://github.com/vestfoldfylke/loglady/issues"
  },
  "homepage": "https://github.com/vestfoldfylke/loglady/#readme",
  "keywords": [
    "log",
    "logging",
    "structured-logging"
  ],
  "author": {
    "name": "Rune Moskvil Lyngås",
    "email": "rune.moskvil.lyngas@vestfoldfylke.no",
    "url": "https://github.com/runely"
  },
  "license": "MIT",
  "description": "My log has something to tell you",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.1",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
