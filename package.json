{
  "name": "@vestfoldfylke/loglady",
  "version": "1.5.3",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node -e \"import('node:fs').then(({writeFileSync})=>writeFileSync('dist/cjs/package.json',JSON.stringify({type:'commonjs'})))\"",
    "pack": "npm run test && rm -rf dist && rm -f vestfoldfylke-loglady-*.tgz && npm run build && npm pack",
    "test": "biome check && node --import tsx --test src/tests/**/*.test.ts",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vestfoldfylke/loglady.git"
  },
  "bugs": {
    "url": "https://github.com/vestfoldfylke/loglady/issues"
  },
  "homepage": "https://github.com/vestfoldfylke/loglady/#readme",
  "keywords": [
    "log",
    "logging",
    "structured-logging"
  ],
  "author": {
    "name": "Rune Moskvil Lyngås",
    "email": "rune.moskvil.lyngas@vestfoldfylke.no",
    "url": "https://github.com/runely"
  },
  "license": "MIT",
  "description": "My log has something to tell you",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
