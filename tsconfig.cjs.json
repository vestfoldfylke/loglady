{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/cjs",
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "emitDeclarationOnly": false,
    "declaration": false,
    "declarationMap": false,
    "verbatimModuleSyntax": false,
    "importHelpers": false
  }
}
